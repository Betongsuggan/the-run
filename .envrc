use flake

# AWS profile used by aws-cli, Pulumi, and the Justfile. Override in
# .envrc.local if you use a different profile name.
export AWS_PROFILE="${AWS_PROFILE:-betongsuggan-prod}"

# Personal overrides (PULUMI_CONFIG_PASSPHRASE, custom AWS_PROFILE, etc.).
# Gitignored — see .envrc.local.example for the template.
source_env_if_exists .envrc.local

# Materialize SSO creds as env vars so tools that don't auto-resolve SSO
# (Pulumi's S3 backend, older AWS SDKs) work without an explicit eval.
# If the session is missing or expired, warn but don't fail — `just sso-login`
# followed by `direnv reload` will refresh.
if command -v aws >/dev/null 2>&1; then
  if creds=$(aws configure export-credentials --profile "$AWS_PROFILE" --format env 2>/dev/null); then
    eval "$creds"
  else
    log_status "no AWS SSO session for profile '$AWS_PROFILE' — run 'just sso-login' then 'direnv reload'"
  fi
fi

# Copy to .env.local for local dev. For production, the value is passed inline
# to `pnpm build` (PUBLIC_API_BASE_URL=https://api.<DOMAIN> pnpm build).
PUBLIC_API_BASE_URL=http://localhost:8080

# Cloudflare Turnstile site key for the registration form. Leave empty to
# skip the widget in dev; set to a real key for prod builds.
PUBLIC_TURNSTILE_SITE_KEY=

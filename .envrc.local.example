# Copy to .envrc.local for personal overrides. `.envrc` sources this file if
# present. Gitignored — safe to put secrets here.
#
# Nothing in here is required: with default settings the repo works out of
# the box once you've run `just bootstrap-pulumi-state`.

# Uncomment to use a different AWS profile than the Justfile default.
# export AWS_PROFILE=my-other-profile

# Uncomment to point Pulumi at a different secrets provider (default is the
# KMS key created by `just bootstrap-pulumi-state`).
# export PULUMI_SECRETS_PROVIDER="awskms://alias/your-other-key?region=eu-north-1"
